rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /user_progress/{docId} {
      // Doc id is "{uid}_{lessonId}". Firebase UIDs contain no underscores, so the
      // first segment is the owner — this also permits reads of not-yet-created docs.
      allow get: if request.auth != null
        && docId.split('_')[0] == request.auth.uid;
      // Queries return only existing docs; restrict to the caller's own data.
      allow list: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null
        && docId.split('_')[0] == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
  }
}
