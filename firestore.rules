rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /users/{userId} {
      // Any signed-in user can view profiles/stats and look up by email (for friends).
      allow read: if request.auth != null;
      // Only the owner can modify their own profile.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /friend_requests/{reqId} {
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
      allow read, delete: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid);
      // Only the recipient can accept/deny.
      allow update: if request.auth != null
        && resource.data.toUid == request.auth.uid;
    }
    match /friendships/{pairId} {
      // Allow reading a not-yet-created friendship (resource == null) so the
      // "already friends?" check doesn't get denied.
      allow get: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.members);
      allow list: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }
    match /user_progress/{docId} {
      // Doc id is "{uid}_{lessonId}". Firebase UIDs contain no underscores, so the
      // first segment is the owner — this also permits reads of not-yet-created docs.
      allow get: if request.auth != null
        && docId.split('_')[0] == request.auth.uid;
      // Queries return only existing docs; restrict to the caller's own data.
      allow list: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null
        && docId.split('_')[0] == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }
  }
}
