# Firebase values from: Firebase Console → Project settings → Your apps → Web app → SDK setup
# Use the firebaseConfig object (Vite requires the VITE_ prefix).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenAI key is NOT a client env var. It lives server-side as a Cloud Function secret:
#   firebase functions:secrets:set OPENAI_API_KEY
# The browser calls the "aiChat" Cloud Function, which holds the key. (See docs/FIREBASE_SETUP.md)
